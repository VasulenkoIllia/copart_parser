# ========================
# App / Runtime
# ========================
APP_NAME=copart-parser
APP_ENV=development
TZ=Europe/Kyiv
LOG_LEVEL=info

# ========================
# Schedule
# 5 runs/day: 00:00, 05:00, 10:00, 15:00, 20:00
# ========================
INGEST_CRON=0 0,5,10,15,20 * * *
PHOTO_RETRY_CRON=
RUN_LOCK_TTL_SEC=16200
SCHEDULER_RUN_ON_START=false

# ========================
# CSV Source
# ========================
CSV_SOURCE_URL=https://allzap.site/copart/salesdata.csv
CSV_AUTH_KEY=change_me
CSV_LOCAL_FILE=
CSV_HTTP_TIMEOUT_MS=60000
CSV_DOWNLOAD_RETRIES=5
CSV_DOWNLOAD_RETRY_DELAY_MS=5000
CSV_STREAM_HIGH_WATER_MARK=1048576
CSV_SKIP_RECORDS_WITH_ERROR=true
CSV_RELAX_QUOTES=true
CSV_PARSE_SKIP_LOG_LIMIT=20

# ========================
# MySQL (Application)
# ========================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=copart
MYSQL_PASSWORD=copart
MYSQL_DATABASE_CORE=copart_core
MYSQL_DATABASE_MEDIA=copart_media
MYSQL_POOL_MIN=5
MYSQL_POOL_MAX=50
MYSQL_CONNECT_TIMEOUT_MS=10000

# ========================
# MySQL (Docker bootstrap)
# ========================
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT_EXTERNAL=3307

# ========================
# CSV Ingest
# ========================
INGEST_BATCH_SIZE=1000
INGEST_UPSERT_CHUNK=500
INGEST_CONCURRENCY=4
INGEST_PROGRESS_EVERY_ROWS=5000
INGEST_MAX_ROWS=0
INGEST_PRUNE_MISSING_LOTS=true
INGEST_ROW_HASH_ALGO=sha256

# ========================
# Photo Processing
# ========================
PHOTO_BATCH_SIZE=500
PHOTO_FETCH_CONCURRENCY=25
PHOTO_WORKER_TOTAL=1
PHOTO_WORKER_INDEX=0
PHOTO_PROGRESS_EVERY_LOTS=100
PHOTO_HTTP_TIMEOUT_MS=20000
PHOTO_ENDPOINT_RETRIES=3
PHOTO_IMAGE_RETRIES=3
PHOTO_LOG_LOT_RESULTS=false
PHOTO_VALIDATE_BY_HEAD_FIRST=true
PHOTO_MIN_WIDTH=1200
PHOTO_MIN_HEIGHT=900
PHOTO_MIN_CONTENT_LENGTH=120000
PHOTO_ACCEPTED_EXTENSIONS=jpg,jpeg,png,webp
PHOTO_RETRY_BASE_DELAY_MINUTES=30
PHOTO_RETRY_MAX_DELAY_MINUTES=1440

# ========================
# Proxy Mode
# HTTP_MODE: direct | proxy | mixed
# ========================
HTTP_MODE=direct
PROXY_LIST_FILE=./proxies.txt
PROXY_LIST=
PROXY_ROTATION=strict
PROXY_MAX_ROUTES_PER_REQUEST=5
PROXY_HEALTHCHECK_URL=https://www.copart.com/
PROXY_AUTO_SELECT_FOR_PHOTO=false
PROXY_AUTO_SELECT_PROBE_LOTS=20
PROXY_FAILURE_COOLDOWN_SEC=300
PROXY_PREFLIGHT_ENABLED=true
PROXY_PREFLIGHT_TIMEOUT_MS=7000
PROXY_PREFLIGHT_CONCURRENCY=100
PROXY_PREFLIGHT_TOP_N=20
PROXY_PREFLIGHT_MIN_WORKING=5
PROXY_PREFLIGHT_STRICT=false

# ========================
# Diagnostics Logging
# ========================
HTTP_LOG_SLOW_REQUEST_MS=3000
HTTP_LOG_RETRY_ATTEMPTS=true

# ========================
# Telegram Alerts
# ========================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SEND_SUCCESS_SUMMARY=true
TELEGRAM_SEND_ERROR_ALERTS=true

# ========================
# Legacy test script (copart_limit_test.js)
# ========================
CONCURRENCY=10
MAX_ROWS=0
REQUEST_TIMEOUT=15000
DELAY_MS=0
TEST_IMAGE=0
OUTPUT_PREFIX=copart_test
DEDUPE_BY_IMAGE_URL=1
